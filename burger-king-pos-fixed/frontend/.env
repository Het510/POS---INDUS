# If you're running everything on the same machine, leave this commented out.
# The app auto-detects the server hostname so it works from any device on the local network.
# REACT_APP_API_URL=http://localhost:5000/api

# If you want to force a specific IP (e.g. when running backend on a different machine):
# REACT_APP_API_URL=http://192.168.1.100:5000/api
